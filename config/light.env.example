# light — infrastructure harness configuration
# Copy to config/light.env and fill in your values.

# ── Domain ───────────────────────────────────────────────────────────────────
LIGHT_DOMAIN="simple-test.org"          # Override with your domain

# ── Environment ──────────────────────────────────────────────────────────────
LIGHT_ENV="dev"                         # dev | staging | prod
LIGHT_PROVIDER="local"                  # local | linode | aws | gcp | on-prem
LIGHT_RUNTIME="hybrid"                  # hybrid | docker | vagrant  (dev only)
                                        # hybrid  = Docker mgmt zone + Vagrant workload VMs (default)
                                        # docker  = everything as Docker containers (no VirtualBox needed)
                                        # vagrant = everything as VirtualBox VMs (legacy)

# ── Naming (hostname pattern: {env}-{location}-{type}-{function}-{seq}) ──────
LIGHT_LOCATION="local"                  # local | vie | lnd | aws-eu | gcp-eu | etc.

# ── Network ───────────────────────────────────────────────────────────────────
MGMT_ZONE_CIDR="10.10.0.0/24"          # Management zone network
WORKLOAD_CIDR="10.20.0.0/24"           # Workload VM network (docker mode only)
MGMT_GATEWAY="10.10.0.1"               # Docker mgmt-zone bridge IP (hybrid mode router)

# ── Management zone service IPs (must be in MGMT_ZONE_CIDR) ─────────────────
IP_JUMPHOST="10.10.0.10"
IP_FOREMAN_DB="10.10.0.19"
IP_FOREMAN="10.10.0.20"
IP_PUPPET="10.10.0.21"
IP_ANSIBLE="10.10.0.22"
IP_CHECKMK="10.10.0.23"
IP_PULP="10.10.0.24"
IP_DNS_PRIMARY="10.10.0.30"
IP_DNS_SECONDARY="10.10.0.31"
IP_NTP_PRIMARY="10.10.0.32"
IP_NTP_SECONDARY="10.10.0.33"

# ── Credentials ───────────────────────────────────────────────────────────────
ADMIN_SSH_KEY_PATH="${HOME}/.ssh/id_ed25519.pub"
ADMIN_SSH_KEY_PRIVATE="${HOME}/.ssh/id_ed25519"
FOREMAN_ADMIN_USER="admin"
FOREMAN_ADMIN_PASS=""                   # set this
FOREMAN_DB_PASS=""                      # set this (Foreman's PostgreSQL password)
CHECKMK_ADMIN_PASS=""                   # set this
PUPPET_CA_SERVER="${IP_PUPPET}"

# ── Cloud provider credentials (fill only the provider you use) ───────────────
# Linode
LINODE_TOKEN=""

# AWS
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-central-1"

# GCP
GCP_PROJECT=""
GCP_REGION="europe-west3"
GOOGLE_APPLICATION_CREDENTIALS=""

# ── Pulp mirror ───────────────────────────────────────────────────────────────
PULP_ADMIN_PASS=""
PULP_SYNC_UBUNTU="true"
PULP_SYNC_DEBIAN="true"
PULP_SYNC_RHEL="false"

# ── Monitoring alerts ─────────────────────────────────────────────────────────
ALERT_EMAIL="linux-admins@${LIGHT_DOMAIN}"
# ALERT_TEAMS_WEBHOOK=""               # optional MS Teams webhook
